<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fluent Design Tokens -->
    <Color x:Key="DeepNavyColor">#0A0E1A</Color>
    <Color x:Key="SurfaceColor">#161B22</Color>
    <Color x:Key="SurfaceLighterColor">#1C2128</Color>
    <Color x:Key="AccentColor">#007AFF</Color>
    <Color x:Key="AccentGlowColor">#4D007AFF</Color>
    <Color x:Key="GlassColor">#20FFFFFF</Color>
    <Color x:Key="TextPrimaryColor">#F0F6FC</Color>
    <Color x:Key="TextSecondaryColor">#8B949E</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource DeepNavyColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceLighterBrush" Color="{StaticResource SurfaceLighterColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlowColor}"/>
    <SolidColorBrush x:Key="GlassBrush" Color="{StaticResource GlassColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    
    <FontFamily x:Key="MainFont">Segoe UI Variable Text, Segoe UI, Inter, Roboto</FontFamily>

</ResourceDictionary>
