<UserControl x:Class="NetTrack.Client.Views.PacketListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:NetTrack.Client.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Search/Filter -->
            <RowDefinition Height="Auto"/> <!-- Quick Chips -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <Border Grid.Row="0" Margin="0,0,0,5" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="4" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="Magnify" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                
                <TextBox Grid.Column="1" 
                         materialDesign:HintAssist.Hint="Filter (e.g., tcp, ip:192.168.1.1)"
                         materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                         BorderThickness="0"
                         VerticalAlignment="Center"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding ApplyFilterCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ToggleButton Style="{StaticResource MaterialDesignActionToggleButton}" IsChecked="{Binding IsAutoScrollEnabled}" ToolTip="Auto-Scroll Lock" Margin="5,0">
                        <Grid>
                             <!-- Unchecked: Unlocked -->
                             <materialDesign:PackIcon Kind="LockOpenVariant" Foreground="{DynamicResource MaterialDesignBodyLight}">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                             </materialDesign:PackIcon>
                             
                             <!-- Checked: Locked -->
                             <materialDesign:PackIcon Kind="Lock" Foreground="{DynamicResource SecondaryHueMidBrush}" Visibility="Collapsed">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                             </materialDesign:PackIcon>
                        </Grid>
                    </ToggleButton>
                    <Button Style="{DynamicResource MaterialDesignFlatButton}" Command="{Binding ApplyFilterCommand}" Content="APPLY"/>
                    
                    <materialDesign:PopupBox Style="{StaticResource MaterialDesignMultiFloatingActionPopupBox}" PlacementMode="BottomAndAlignRights" ToolTip="Export" Margin="5,0">
                        <materialDesign:PopupBox.ToggleContent>
                            <materialDesign:PackIcon Kind="FileExport" Foreground="{DynamicResource MaterialDesignBody}"/>
                        </materialDesign:PopupBox.ToggleContent>
                        <StackPanel>
                            <Button ToolTip="Export to JSON" Command="{Binding ExportPacketsCommand}" CommandParameter="JSON">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CodeJson" Margin="0,0,5,0"/>
                                    <TextBlock Text="JSON"/>
                                </StackPanel>
                            </Button>
                            <Button ToolTip="Export to CSV" Command="{Binding ExportPacketsCommand}" CommandParameter="CSV">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileDelimited" Margin="0,0,5,0"/>
                                    <TextBlock Text="CSV"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </materialDesign:PopupBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Quick Filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="QUICK FILTERS:" VerticalAlignment="Center" Margin="5,0,10,0" FontWeight="Bold" FontSize="10" Opacity="0.6"/>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ApplyQuickFilterCommand}" CommandParameter="" Content="ALL" Margin="0,0,5,0" Height="24" Padding="10,0" FontSize="10"/>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ApplyQuickFilterCommand}" CommandParameter="TCP" Content="TCP" Margin="0,0,5,0" Height="24" Padding="10,0" FontSize="10"/>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ApplyQuickFilterCommand}" CommandParameter="UDP" Content="UDP" Margin="0,0,5,0" Height="24" Padding="10,0" FontSize="10"/>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ApplyQuickFilterCommand}" CommandParameter="DNS" Content="DNS" Margin="0,0,5,0" Height="24" Padding="10,0" FontSize="10"/>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ApplyQuickFilterCommand}" CommandParameter="HTTP" Content="HTTP" Margin="0,0,5,0" Height="24" Padding="10,0" FontSize="10"/>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ApplyQuickFilterCommand}" CommandParameter="TLS" Content="TLS" Margin="0,0,5,0" Height="24" Padding="10,0" FontSize="10"/>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ApplyQuickFilterCommand}" CommandParameter="ARP" Content="ARP" Margin="0,0,5,0" Height="24" Padding="10,0" FontSize="10"/>
        </StackPanel>

        <!-- Packet List -->
        <DataGrid Grid.Row="2"
                  x:Name="PacketsGrid"
                  ItemsSource="{Binding PacketsView}" 
                  SelectedItem="{Binding SelectedPacket}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  mah:ScrollViewerHelper.IsHorizontalScrollWheelEnabled="True"
                  AlternationCount="2"
                  Style="{DynamicResource MaterialDesignDataGrid}">
            
            <DataGrid.Resources>
                <!-- <converters:PacketColorConverter x:Key="PacketColorConverter"/> -->
                <Style TargetType="TextBlock">
                     <Setter Property="Foreground" Value="Black"/> <!-- Text needs to be dark on pastel backgrounds -->
                     <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
                <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                    <!-- <Setter Property="Background" Value="{Binding Protocol, Converter={StaticResource PacketColorConverter}}"/> -->
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                             <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                             <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                             <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="NO." Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="TIME" Binding="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" Width="120"/>
                <DataGridTextColumn Header="SOURCE" Binding="{Binding SourceIP}" Width="150"/>
                <DataGridTextColumn Header="DESTINATION" Binding="{Binding DestinationIP}" Width="150"/>
                
                <DataGridTemplateColumn Header="PROTO" Width="90" SortMemberPath="Protocol">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" CornerRadius="3" Padding="8,2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Protocol}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="LEN" Binding="{Binding Length}" Width="80"/>
                <DataGridTextColumn Header="INFO" Binding="{Binding Info}" Width="*"/>
            </DataGrid.Columns>
            
            <DataGrid.ContextMenu>
                 <ContextMenu>
                    <MenuItem Header="Copy Source IP" Command="{Binding CopySourceIpCommand}">
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="ContentCopy"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Copy Destination IP" Command="{Binding CopyDestinationIpCommand}">
                         <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="ContentCopy"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Filter by Protocol" Command="{Binding FilterByProtocolCommand}">
                         <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="FilterVariant"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Follow Stream" Command="{Binding FilterByStreamCommand}">
                         <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="Eye"/>
                        </MenuItem.Icon>
                    </MenuItem>
                 </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </Grid>
</UserControl>
